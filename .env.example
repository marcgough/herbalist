# Cloudflare deploy automation. Leave blank if using an authenticated Wrangler session locally.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional local binding helper. The guarded GitHub production workflow resolves this
# value by D1 database name during the approved run.
HERBALISTI_D1_DATABASE_ID=

# Protected scheduled-news manual refresh.
FEED_ADMIN_TOKEN=

# Protected Kie.ai Seedance 2.0 video job creation/status checks.
KIE_API_KEY=
MEDIA_ADMIN_TOKEN=

# Optional: powers hosted herbal chat synthesis and any future repeatable server-side
# OpenAI image generation workflow.
OPENAI_API_KEY=
OPENAI_HERBAL_CHAT_MODEL=gpt-5.4-mini

# Separate local semantic archive for the Herbalisti corpus. Leave CORPUS_MEMORY_STORE_DIR
# blank to use the default project-local store under corpus-memory/store.
CORPUS_MEMORY_NAME=Corpus Memory
CORPUS_MEMORY_HOST=127.0.0.1
CORPUS_MEMORY_PORT=8766
CORPUS_MEMORY_URL=http://127.0.0.1:8766
CORPUS_MEMORY_STORE_DIR=
